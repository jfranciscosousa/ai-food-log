generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgres"
}

model FoodEntryItem {
  id                      String              @id @default(uuid())
  name                    String
  servingSize             Float
  calories                Float
  protein                 Float
  carbs                   Float
  fat                     Float
  fiber                   Float
  foodEntryId             String
  foodEntry               FoodEntry                @relation(fields: [foodEntryId], references: [id], onDelete: Cascade)
}

model FoodEntry {
  id                      String              @id @default(uuid())
  content                 String
  name                    String
  icon                    String?
  calories                Float
  protein                 Float
  carbs                   Float
  fat                     Float
  fiber                   Float
  aiResponse              Json
  day                     DateTime            @default(now())
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  userId                  String
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                   FoodEntryItem[]
  fromImage               Boolean             @default(false)
}

enum FitnessLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum WeightLossGoal {
  MAINTAIN
  LOW
  MEDIUM
  HIGH
}

enum Gender {
  MALE
  FEMALE
}

model WorkoutPlan {
  id          String   @id @default(uuid())
  day         DateTime
  name        String
  content     String
  exercises   Json
  aiGenerated Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id              String                 @id @default(uuid())
  email           String                 @unique
  name            String
  password        String
  age             Int                    @default(0)
  height          Float
  weight          Float
  bmr             Float
  bmi             Float
  gender          Gender                  @default(MALE)
  fitnessLevel    FitnessLevel
  weightLossGoal  WeightLossGoal          @default(LOW)
  targetCalories       Float?                 @default(2000)
  targetProtein        Float?
  targetCarbs          Float?
  targetFat            Float?
  targetFiber          Float?
  workoutPreferences   String?
  createdAt            DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  featureFlags    Json                    @default("{}")
  foodEntries                             FoodEntry[]
  workoutPlans                            WorkoutPlan[]
}
