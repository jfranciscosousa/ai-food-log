generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgres"
  url               = env("DATABASE_URL")
}

model FoodEntryItem {
  id                      String              @id @default(uuid())
  name                    String
  servingSize             Decimal
  calories                Decimal
  protein                 Decimal
  carbs                   Decimal
  fat                     Decimal
  fiber                   Decimal
  foodEntryId             String
  foodEntry               FoodEntry                @relation(fields: [foodEntryId], references: [id], onDelete: Cascade)
}

model FoodEntry {
  id                      String              @id @default(uuid())
  content                 String
  name                    String
  calories                Decimal
  protein                 Decimal
  carbs                   Decimal
  fat                     Decimal
  fiber                   Decimal
  aiResponse              Json
  day                     DateTime            @default(now())
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  userId                  String
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                   FoodEntryItem[]
}

enum FitnessLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum WeightLossGoal {
  MAINTAIN
  LOW
  MEDIUM
  HIGH
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id              String                 @id @default(uuid())
  email           String                 @unique
  name            String
  password        String
  age             Int                    @default(0)
  height          Decimal
  weight          Decimal
  bmr             Decimal
  bmi             Decimal
  gender          Gender                  @default(MALE)
  fitnessLevel    FitnessLevel
  weightLossGoal  WeightLossGoal          @default(LOW)
  targetCalories  Decimal                 @default(2000)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  featureFlags    Json                    @default("{}")
  foodEntries                             FoodEntry[]
}
