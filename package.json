    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "isbot": "^5.1.27",
    "lodash": "^4.17.21",
    "lucide-react": "^0.503.0",
    "openai": "^4.96.2",
    "react": "^18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.5.3",
    "tailwind-merge": "^3.2.0",
