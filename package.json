{
  "name": "vigor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "ci": "pnpm run lint && pnpm run ts-check && npx playwright install && pnpm run test",
    "clean": "rm -rf .eslintcache playwright-report build public/build .cache node_modules test-results",
    "deploy": "pnpm run ts-run scripts/validate-config.ts && pnpm run generate && prisma db push && pnpm run build",
    "generate": "prisma generate",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/nodejs_eyJydW50aW1lIjoibm9kZWpzIn0/index.js",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" --cache",
    "prepare": "[ \"$NODE_ENV\" != \"production\" ] && husky || :",
    "test": "pnpm run test:vitest && pnpm run test:e2e",
    "test:e2e": "dotenv -e .env.test -- bash -c 'prisma db push --accept-data-loss && prisma generate && pnpm run build && playwright test'",
    "test:e2e-ui": "dotenv -e .env.test -- bash -c 'prisma db push --accept-data-loss && prisma generate && pnpm run build && playwright test --ui'",
    "test:e2e-quick": "dotenv -e .env.test -- bash -c 'playwright test'",
    "test:vitest": "vitest --run",
    "test:vitest:watch": "vitest",
    "ts-check": "react-router typegen && tsc --project tsconfig.json --skipLibCheck --noEmit",
    "ts-watch": "react-router typegen && tsc --project tsconfig.json --watch --skipLibCheck --noEmit",
    "ts-run": "dotenv tsx",
    "validate-env": "pnpm run ts-run scripts/validate-config.ts",
    "generate-pwa-assets": "pwa-assets-generator",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "eslint --cache --fix"
  },
