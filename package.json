{
  "name": "ai-food-log",
  "private": true,
  "description": "A Remix starter with Prisma",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "ci": "npm run lint && npm run ts-check && npx playwright install && npm run test",
    "clean": "rm -rf .eslintcache playwright-report build public/build .cache node_modules test-results",
    "deploy": "npm run ts-run tasks/validateConfig.ts && prisma generate && prisma db push && npm run build",
    "dev": "remix vite:dev",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" --cache",
    "prepare": "[ \"$NODE_ENV\" != \"production\" ] && husky || :",
    "start": "remix-serve ./build/server/index.js",
    "test": "npm run test:vitest && npm run test:e2e",
    "test:e2e": "dotenv -e .env.test -- bash -c 'prisma db push -- --force && npm run build && playwright test'",
    "test:e2e-ui": "dotenv -e .env.test -- bash -c 'prisma db push -- --force && npm run build && playwright test --ui'",
    "test:e2e-quick": "dotenv -e .env.test -- bash -c 'playwright test'",
    "test:vitest": "vitest --run",
    "test:vitest:watch": "vitest",
    "ts-check": "tsc --project tsconfig.json --noEmit --skipLibCheck",
    "ts-run": "dotenv ts-node",
    "validate-env": "npm run ts-run tasks/validateConfig.ts"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "eslint --cache --fix"
  },
  "dependencies": {
    "@prisma/client": "5.21.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "2.13.1",
    "@remix-run/serve": "^2.13.1",
    "accept-language-parser": "^1.5.0",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "isbot": "^5.1.17",
    "lodash": "^4.17.21",
    "lucide-react": "^0.453.0",
    "openai": "^4.68.2",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remix": "2.13.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zod-error": "^1.5.0",
    "zod-form-data": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.1",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.13.0",
    "@faker-js/faker": "^9.0.3",
    "@playwright-testing-library/test": "^4.5.0",
    "@playwright/test": "^1.48.1",
    "@remix-run/dev": "^2.13.1",
    "@remix-run/eslint-config": "^2.13.1",
    "@remix-run/testing": "^2.13.1",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@types/accept-language-parser": "^1.5.6",
    "@types/lodash": "^4.17.12",
    "@types/node": "^22.7.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "@vitest/ui": "^2.1.3",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-testing-library": "^6.4.0",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "5.21.1",
    "remix-development-tools": "^4.7.3",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "type-fest": "^4.26.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=18.18.2"
  }
}
